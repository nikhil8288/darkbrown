{%- raw -%}
<div id="db-md-root">
<script src="/assets/darkbrown_md/js/support.js"></script>
<x-dc>
<helmet>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Mulish:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Mulish',-apple-system,sans-serif;-webkit-font-smoothing:antialiased}
    ::-webkit-scrollbar{width:9px;height:9px}
    ::-webkit-scrollbar-thumb{background:#5D4037;border-radius:6px;border:2px solid #241511}
    ::-webkit-scrollbar-track{background:transparent}
    .noscroll::-webkit-scrollbar{height:0}
    @keyframes drawLine{to{stroke-dashoffset:0}}
  </style>
</helmet>
<div style="{{ rootStyle }}">

  <!-- ============ APP SHELL ============ -->
  <div style="{{ appStyle }}">

    <!-- SCRIM for mobile drawer -->
    <sc-if value="{{ showScrim }}" hint-placeholder-val="">
      <div onClick="{{ closeNav }}" style="position:absolute;inset:0;background:rgba(0,0,0,.55);z-index:55"></div>
    </sc-if>

    <!-- SIDEBAR -->
    <sc-if value="{{ showSidebar }}" hint-placeholder-val="{{ true }}">
    <aside style="{{ sidebarStyle }}">
      <div style="height:56px;flex-shrink:0;display:flex;align-items:center;gap:10px;padding:0 16px;border-bottom:1px solid #4E342E">
        <div style="width:28px;height:28px;border-radius:7px;background:#4E342E;border:1px solid #C9A86A;display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-weight:700;font-size:14px;letter-spacing:.5px;color:#C9A86A;flex-shrink:0">DB</div>
        <div style="overflow:hidden;flex:1">
          <div style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:16px;letter-spacing:.2px;line-height:1.05;white-space:nowrap">Darkbrown Real Estate</div>
          <div style="font-size:10.5px;color:#8A7866;line-height:1.3">Leasing & Subleasing · Doha</div>
        </div>
        <sc-if value="{{ isMobile }}" hint-placeholder-val="">
          <button onClick="{{ closeNav }}" style="width:30px;height:30px;border:none;background:transparent;color:#A89684;cursor:pointer;display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"></path></svg></button>
        </sc-if>
      </div>
      <div style="padding:14px 12px 8px;font-size:10.5px;font-weight:600;letter-spacing:.6px;text-transform:uppercase;color:#8A7866">Workspaces</div>
      <nav style="flex:1;overflow-y:auto;padding:0 8px 16px">
        <sc-for list="{{ nav }}" as="item" hint-placeholder-count="11">
          <a href="#" onClick="{{ item.onClick }}" style="{{ item.style }}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><path d="{{ item.iconPath }}"></path></svg>
            <span style="flex:1">{{ item.label }}</span>
            <sc-if value="{{ item.badge }}" hint-placeholder-val="">
              <span style="font-size:10px;font-weight:600;background:#4E342E;color:#D7C8B6;border-radius:10px;padding:1px 7px">{{ item.badge }}</span>
            </sc-if>
          </a>
        </sc-for>
      </nav>
      <div style="flex-shrink:0;border-top:1px solid #4E342E;padding:10px 12px;display:flex;align-items:center;gap:10px">
        <div style="width:30px;height:30px;border-radius:50%;background:#5D4037;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:12px;color:#E8DDD2;flex-shrink:0">KA</div>
        <div style="flex:1;overflow:hidden">
          <div style="font-weight:550;font-size:12.5px;line-height:1.1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">Khalid Al-Mansoori</div>
          <div style="font-size:10.5px;color:#8A7866">Managing Director</div>
        </div>
      </div>
    </aside>
    </sc-if>

    <!-- MAIN -->
    <div style="{{ mainStyle }}">

      <!-- TOPBAR: DESKTOP -->
      <sc-if value="{{ showDesktopBar }}" hint-placeholder-val="{{ true }}">
        <header style="height:56px;flex-shrink:0;background:#3E2723;border-bottom:1px solid #4E342E;display:flex;align-items:center;gap:16px;padding:0 20px">
          <div style="display:flex;align-items:center;gap:7px;font-size:12.5px;color:#A89684">
            <span>Home</span><span style="color:#6B5648">/</span><span style="color:#F4EDE6;font-weight:550">Managing Director</span>
          </div>
          <div style="flex:1;max-width:440px;margin:0 auto;position:relative">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#8A7866" stroke-width="2" stroke-linecap="round" style="position:absolute;left:11px;top:50%;transform:translateY(-50%)"><circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4-4"></path></svg>
            <input placeholder="Search or type a command   (Ctrl + G)" style="width:100%;height:34px;background:#241511;border:1px solid #5D4037;border-radius:7px;padding:0 12px 0 32px;color:#F4EDE6;font-size:12.5px;font-family:inherit;outline:none" />
          </div>
          <button style="width:32px;height:32px;border-radius:7px;background:transparent;border:none;color:#A89684;cursor:pointer;display:flex;align-items:center;justify-content:center;position:relative" style-hover="background:#4E342E;color:#F4EDE6">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9M13.7 21a2 2 0 0 1-3.4 0"></path></svg>
            <span style="position:absolute;top:5px;right:6px;width:7px;height:7px;background:#E08A66;border-radius:50%;border:1.5px solid #3E2723"></span>
          </button>
          <button style="width:32px;height:32px;border-radius:7px;background:transparent;border:none;color:#A89684;cursor:pointer;display:flex;align-items:center;justify-content:center" style-hover="background:#4E342E;color:#F4EDE6">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M9.1 9a3 3 0 0 1 5.8 1c0 2-3 3-3 3"></path><path d="M12 17h.01"></path></svg>
          </button>
        </header>
      </sc-if>

      <!-- TOPBAR: MOBILE -->
      <sc-if value="{{ showMobileBar }}" hint-placeholder-val="">
        <header style="height:52px;flex-shrink:0;background:#3E2723;border-bottom:1px solid #4E342E;display:flex;align-items:center;gap:12px;padding:0 12px">
          <button onClick="{{ toggleNav }}" style="width:34px;height:34px;border-radius:8px;border:none;background:transparent;color:#E8DDD2;cursor:pointer;display:flex;align-items:center;justify-content:center" style-hover="background:#4E342E"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"></path></svg></button>
          <div style="flex:1;font-weight:600;font-size:14px">Managing Director</div>
          <button style="width:34px;height:34px;border-radius:8px;border:none;background:transparent;color:#A89684;cursor:pointer;display:flex;align-items:center;justify-content:center;position:relative" style-hover="background:#4E342E"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9M13.7 21a2 2 0 0 1-3.4 0"></path></svg><span style="position:absolute;top:7px;right:8px;width:7px;height:7px;background:#E08A66;border-radius:50%;border:1.5px solid #3E2723"></span></button>
        </header>
      </sc-if>

      <!-- CONTENT -->
      <main class="noscroll" style="{{ contentStyle }}">
        <div style="{{ innerStyle }}">

          <!-- PAGE HEADER -->
          <div style="margin-bottom:14px">
            <div style="display:flex;align-items:center;gap:10px">
              <h1 style="{{ h1Style }}">Managing Director</h1>
              <span style="font-size:11px;font-weight:600;color:#5FB89A;background:rgba(46,107,87,.18);border:1px solid rgba(95,184,154,.35);padding:2px 9px;border-radius:20px">Live</span>
            </div>
            <p style="color:#A38E7C;font-size:12.5px;margin-top:5px">{{ subtitle }}</p>
          </div>

          <!-- TABS -->
          <div class="noscroll" style="display:flex;gap:2px;border-bottom:1px solid #4E342E;margin-bottom:18px;overflow-x:auto;overflow-y:hidden;white-space:nowrap">
            <sc-for list="{{ tabs }}" as="t" hint-placeholder-count="5">
              <button onClick="{{ t.onClick }}" style="{{ t.style }}">{{ t.label }}</button>
            </sc-for>
          </div>

          <!-- ===================== OVERVIEW ===================== -->
          <sc-if value="{{ showOverview }}" hint-placeholder-val="{{ true }}">

            <!-- TIME SWITCHER -->
            <div class="noscroll" style="{{ tfWrapStyle }}">
              <sc-for list="{{ timeframes }}" as="f" hint-placeholder-count="4">
                <button onClick="{{ f.onClick }}" style="{{ f.style }}">{{ f.label }}</button>
              </sc-for>
            </div>

            <!-- ALERT STRIP -->
            <sc-if value="{{ showAlerts }}" hint-placeholder-val="{{ true }}">
              <div style="background:#3E2723;border:1px solid #5D4037;border-left:3px solid #C9A86A;border-radius:11px;padding:12px 14px;margin-bottom:18px">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#C9A86A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0zM12 9v4M12 17h.01"></path></svg>
                  <span style="font-size:13px;font-weight:600;color:#E0CBA0">Needs your attention</span>
                  <span style="font-size:10.5px;font-weight:700;color:#C9A86A;background:rgba(201,168,106,.18);border-radius:20px;padding:1px 8px">{{ alertCount }}</span>
                </div>
                <div style="display:flex;flex-direction:column;gap:7px">
                  <sc-for list="{{ alerts }}" as="a" hint-placeholder-count="3">
                    <div onClick="{{ a.onClick }}" style="display:flex;align-items:center;gap:11px;padding:9px 11px;background:#2E1C17;border-radius:8px;cursor:pointer;transition:background .12s" style-hover="background:#4E342E">
                      <span style="width:26px;height:26px;border-radius:7px;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:{{ a.col }};background:{{ a.bg }}">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="{{ a.iconPath }}"></path></svg>
                      </span>
                      <span style="flex:1;font-size:12.5px;color:#E8DDD2;line-height:1.35">{{ a.msg }}</span>
                      <span style="font-size:11px;color:#8A7866;white-space:nowrap;display:flex;align-items:center;gap:3px">{{ a.drillLabel }}<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></span>
                      <button onClick="{{ a.onDismiss }}" style="width:24px;height:24px;border-radius:6px;border:none;background:transparent;color:#8A7866;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0" style-hover="background:#5D4037;color:#E8DDD2"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"></path></svg></button>
                    </div>
                  </sc-for>
                </div>
              </div>
            </sc-if>
            <sc-if value="{{ showHealthy }}" hint-placeholder-val="">
              <div style="display:flex;align-items:center;gap:11px;background:#3E2723;border:1px solid #3a4a3f;border-left:3px solid #5FB89A;border-radius:11px;padding:13px 15px;margin-bottom:18px">
                <span style="width:28px;height:28px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:#5FB89A;background:rgba(46,107,87,.18)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg></span>
                <div>
                  <div style="font-size:13px;font-weight:600;color:#9FD9BE">All clear</div>
                  <div style="font-size:11.5px;color:#A38E7C;margin-top:1px">No arrears spikes, expiries, or approvals need you right now.</div>
                </div>
              </div>
            </sc-if>

            <!-- HEALTH CARDS -->
            <div style="font-size:11px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:#8A7866;margin-bottom:10px">Business Health · tap any card to drill in</div>
            <div style="{{ cardGridStyle }}">
              <sc-for list="{{ cards }}" as="k" hint-placeholder-count="9">
                <div onClick="{{ k.onClick }}" style="{{ k.cardStyle }}" style-hover="border-color:#39424d;transform:translateY(-2px)">
                  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:13px">
                    <span style="width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;color:{{ k.tint }};background:{{ k.tintBg }}">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="{{ k.iconPath }}"></path></svg>
                    </span>
                    <span style="{{ k.deltaStyle }}">
                      <sc-if value="{{ k.showArrow }}" hint-placeholder-val="{{ true }}">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="{{ k.deltaArrow }}"></path></svg>
                      </sc-if>
                      {{ k.delta }}
                    </span>
                  </div>
                  <div style="{{ k.valueStyle }}">{{ k.value }}</div>
                  <div style="font-size:12px;color:#D7C8B6;margin-top:6px;font-weight:550">{{ k.label }}</div>
                  <div style="font-size:11px;color:#8A7866;margin-top:2px">{{ k.sub }}</div>
                  <div style="display:flex;align-items:center;gap:3px;font-size:10.5px;color:#7BC3A8;margin-top:10px;font-weight:550">View in {{ k.drillLabel }}<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></div>
                </div>
              </sc-for>
            </div>

            <!-- PER-BUILDING MARGIN -->
            <div style="background:#3E2723;border:1px solid #4E342E;border-radius:12px;padding:18px 18px 8px;margin-top:18px">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
                <div style="font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:600;letter-spacing:.2px">Per-Building Margin</div>
                <div style="display:flex;align-items:center;gap:3px;font-size:11px;color:#7BC3A8;font-weight:550;cursor:pointer">Portfolio P&amp;L<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></div>
              </div>
              <div style="font-size:11.5px;color:#A38E7C;margin-bottom:10px">Ranked best → worst · (income − head-lease) / income</div>
              <sc-for list="{{ perBuilding }}" as="b" hint-placeholder-count="5">
                <div style="display:flex;align-items:center;gap:14px;padding:11px 4px;border-bottom:1px solid #4E342E">
                  <div style="width:180px;flex-shrink:0;min-width:0">
                    <div style="font-size:12.5px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ b.name }}</div>
                    <div style="font-size:11px;color:#A89684;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ b.spread }}</div>
                  </div>
                  <div style="flex:1;height:8px;background:#2E1C17;border-radius:5px;overflow:hidden;min-width:50px"><div style="height:100%;width:{{ b.barW }};background:{{ b.col }};border-radius:5px;transition:width .6s ease"></div></div>
                  <span style="{{ b.pillStyle }}">{{ b.marginPct }}</span>
                </div>
              </sc-for>
            </div>

            <!-- SINGLE TREND CHART -->
            <div style="background:#3E2723;border:1px solid #4E342E;border-radius:12px;padding:18px 18px 14px;margin-top:18px">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:14px">
                <div>
                  <div style="font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:600;letter-spacing:.2px">Rent Collected vs Billed</div>
                  <div style="font-size:11.5px;color:#A38E7C;margin-top:2px">{{ chartSub }}</div>
                </div>
                <div style="display:flex;align-items:center;gap:14px;font-size:11.5px;color:#D7C8B6">
                  <span style="display:flex;align-items:center;gap:6px"><span style="width:9px;height:9px;border-radius:2px;background:#5D4037"></span>Billed</span>
                  <span style="display:flex;align-items:center;gap:6px"><span style="width:9px;height:9px;border-radius:2px;background:#2E6B57"></span>Collected</span>
                  <span style="display:flex;align-items:center;gap:6px"><span style="width:9px;height:9px;border-radius:2px;background:#C9A86A"></span>Below target</span>
                </div>
              </div>
              <sc-if value="{{ chartEmpty }}" hint-placeholder-val="">
                <div style="height:170px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:#8A7866;border:1px dashed #5D4037;border-radius:10px">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"></path><path d="M7 14l4-4 3 3 5-6"></path></svg>
                  <div style="font-size:12.5px">No billing data yet for today</div>
                </div>
              </sc-if>
              <sc-if value="{{ chartBars }}" hint-placeholder-val="{{ true }}">
                <svg viewBox="0 0 560 200" style="width:100%;height:auto;display:block">
                  <line x1="34" y1="30" x2="545" y2="30" stroke="#4E342E" stroke-width="1"></line>
                  <line x1="34" y1="70" x2="545" y2="70" stroke="#4E342E" stroke-width="1"></line>
                  <line x1="34" y1="110" x2="545" y2="110" stroke="#4E342E" stroke-width="1"></line>
                  <text x="28" y="34" text-anchor="end" font-size="9" fill="#8A7866">6</text>
                  <text x="28" y="74" text-anchor="end" font-size="9" fill="#8A7866">4</text>
                  <text x="28" y="114" text-anchor="end" font-size="9" fill="#8A7866">2</text>
                  <text x="28" y="153" text-anchor="end" font-size="9" fill="#8A7866">0</text>
                  <text x="6" y="22" font-size="9" fill="#8A7866">QAR M</text>
                  <line x1="40" y1="46" x2="545" y2="46" stroke="#C9A86A" stroke-width="1.3" stroke-dasharray="5 5" opacity="0.6"></line>
                  <text x="541" y="42" text-anchor="end" font-size="9" fill="#C9A86A">Target</text>
                  <rect x="52" y="62" width="44" height="88" rx="4" fill="#5D4037"></rect><rect x="52" y="74" width="44" height="76" rx="4" fill="#2E6B57"></rect>
                  <rect x="135" y="46" width="44" height="104" rx="4" fill="#5D4037"></rect><rect x="135" y="58" width="44" height="92" rx="4" fill="#2E6B57"></rect>
                  <rect x="218" y="78" width="44" height="72" rx="4" fill="#5D4037"></rect><rect x="218" y="90" width="44" height="60" rx="4" fill="#C9A86A"></rect>
                  <rect x="301" y="34" width="44" height="116" rx="4" fill="#5D4037"></rect><rect x="301" y="46" width="44" height="104" rx="4" fill="#2E6B57"></rect>
                  <rect x="384" y="54" width="44" height="96" rx="4" fill="#5D4037"></rect><rect x="384" y="66" width="44" height="84" rx="4" fill="#2E6B57"></rect>
                  <rect x="467" y="30" width="44" height="120" rx="4" fill="#5D4037"></rect><rect x="467" y="42" width="44" height="108" rx="4" fill="#5FB89A"></rect>
                  <line x1="34" y1="150" x2="545" y2="150" stroke="#5D4037" stroke-width="1.2"></line>
                </svg>
                <div style="display:flex;justify-content:space-between;margin-top:6px;padding:0 0 0 40px;font-size:10.5px;color:#8A7866">
                  <sc-for list="{{ chartLabels }}" as="l" hint-placeholder-count="6"><span style="flex:1;text-align:center">{{ l }}</span></sc-for>
                </div>
              </sc-if>
            </div>

            <!-- PENDING APPROVAL (overview) -->
            <div style="background:#3E2723;border:1px solid #4E342E;border-radius:12px;padding:18px 4px 8px 18px;margin-top:18px">
              <div style="display:flex;align-items:center;justify-content:space-between;padding-right:14px;margin-bottom:14px">
                <div style="display:flex;align-items:center;gap:9px"><div style="font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:600;letter-spacing:.2px">Pending Your Approval</div><span style="font-size:10.5px;font-weight:700;color:#C9A86A;background:rgba(201,168,106,.18);border-radius:20px;padding:1px 8px">5</span></div>
                <div onClick="{{ goFinance }}" style="display:flex;align-items:center;gap:3px;font-size:11.5px;color:#7BC3A8;font-weight:550;cursor:pointer">View all<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></div>
              </div>
              <div style="display:flex;flex-direction:column">
                <sc-for list="{{ approvals }}" as="a" hint-placeholder-count="5">
                  <div style="display:flex;align-items:center;gap:12px;padding:11px 14px 11px 4px;border-bottom:1px solid #4E342E;cursor:pointer;border-radius:6px;transition:background .12s" style-hover="background:#2E1C17">
